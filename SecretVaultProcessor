@Slf4j
public class SecretVaultProcessor implements EnvironmentPostProcessor {

    @Override
    public void postProcessEnvironment(
            ConfigurableEnvironment environment, SpringApplication application) {
        try {
            log.info("Inside action service's SecretVaultProcessor");

            // ─── Read base config ──────────────────────────────────────────
            String secretServiceBaseUrl = environment.getProperty(SECRET_BASE_URL.getName());
            String secretApi            = environment.getProperty(SECRET_API.getName());

            // ─── DB & Kafka service accounts ──────────────────────────────
            String dbServiceAccount    = environment.getProperty(DB_SERVICE_ACCOUNT.getName());
            String kafkaServiceAccount = environment.getProperty(KAFKA_SERVICE_ACCOUNT.getName());

            // ─── OAuth service accounts ───────────────────────────────────
            String centrlServiceAccount       = environment.getProperty(CENTRL_SERVICE_ACCOUNT.getName());
            String paymentServiceAccount      = environment.getProperty(PAYMENT_SERVICE_ACCOUNT.getName());
            String notificationServiceAccount = environment.getProperty(NOTIFICATION_SERVICE_ACCOUNT.getName());

            String secretApiUrl = secretServiceBaseUrl + secretApi;

            // ─── Validate required properties ─────────────────────────────
            if (StringUtils.isEmpty(secretServiceBaseUrl)
                    || StringUtils.isEmpty(dbServiceAccount)
                    || StringUtils.isEmpty(kafkaServiceAccount)
                    || StringUtils.isEmpty(centrlServiceAccount)
                    || StringUtils.isEmpty(paymentServiceAccount)
                    || StringUtils.isEmpty(notificationServiceAccount)) {
                log.error(
                    "Secret service URL and all service accounts must not be EMPTY or NULL. "
                    + "Secret URL: {}, DB: {}, Kafka: {}, Centrl: {}, Payment: {}, Notification: {}",
                    secretServiceBaseUrl,
                    dbServiceAccount,
                    kafkaServiceAccount,
                    centrlServiceAccount,
                    paymentServiceAccount,
                    notificationServiceAccount);
                throw new IllegalStateException(
                    "Secret service URL or one or more service accounts must not be EMPTY or NULL");
            }

            // ─── Fetch all secrets in one call ────────────────────────────
            Map<String, String> secrets = fetchSecrets(
                secretApiUrl,
                dbServiceAccount,
                kafkaServiceAccount,
                centrlServiceAccount,
                paymentServiceAccount,
                notificationServiceAccount
            );

            environment
                .getPropertySources()
                .addFirst(new MapPropertySource(GENESIS_SECRETS_MAPPING_SOURCE.getName(), secrets));

            log.info("Successfully loaded all secrets into Spring environment");

        } catch (Exception exception) {
            log.error("Failed to fetch secrets for Action Service application", exception);
            throw new ActionServiceException(exception.getMessage(), exception);
        }
    }

    // ─── Fetch Secrets ────────────────────────────────────────────────────────

    private Map<String, String> fetchSecrets(
            String secretServiceUrl,
            String dbServiceAccount,
            String kafkaServiceAccount,
            String centrlServiceAccount,
            String paymentServiceAccount,
            String notificationServiceAccount) {

        RestTemplate restTemplate = buildRestTemplate();

        HttpHeaders headers = new HttpHeaders();
        headers.setContentType(MediaType.APPLICATION_JSON);
        headers.set(CORRELATION_ID_HEADER.getName(), UUID.randomUUID().toString());

        // Send all service accounts in one request
        SecretsRequest secretsRequest = new SecretsRequest(
            List.of(
                dbServiceAccount,
                kafkaServiceAccount,
                centrlServiceAccount,
                paymentServiceAccount,
                notificationServiceAccount
            )
        );

        HttpEntity<SecretsRequest> secretRequestEntity = new HttpEntity<>(secretsRequest, headers);

        ResponseEntity<Map<String, String>> response =
            restTemplate.exchange(
                secretServiceUrl,
                HttpMethod.POST,
                secretRequestEntity,
                new ParameterizedTypeReference<Map<String, String>>() {});

        if (response.getStatusCode().is2xxSuccessful()) {
            Map<String, String> data =
                Optional.ofNullable(response.getBody())
                    .orElseThrow(() -> new IllegalStateException("Secret API returned empty body"));

            Map<String, String> secrets = new HashMap<>();

            // ─── DB & Kafka ───────────────────────────────────────────────
            secrets.put(DATABASE_PASSWORD.getName(),
                Optional.ofNullable(data.get(dbServiceAccount))
                    .orElseThrow(() -> new IllegalStateException("DB secret missing from response")));

            secrets.put(KAFKA_PASSWORD.getName(),
                Optional.ofNullable(data.get(kafkaServiceAccount))
                    .orElseThrow(() -> new IllegalStateException("Kafka secret missing from response")));

            // ─── Centrl OAuth (password grant — needs all 4 fields) ───────
            Map<String, String> centrlSecrets = parseJsonSecret(
                data.get(centrlServiceAccount), "centrl");
            secrets.put("action.oauth.centrl.client-id",     
                getMandatorySecret(centrlSecrets, "client_id",     "centrl"));
            secrets.put("action.oauth.centrl.client-secret", 
                getMandatorySecret(centrlSecrets, "client_secret", "centrl"));
            secrets.put("action.oauth.centrl.username",      
                getMandatorySecret(centrlSecrets, "username",      "centrl"));
            secrets.put("action.oauth.centrl.password",      
                getMandatorySecret(centrlSecrets, "password",      "centrl"));

            // ─── Payment OAuth (client_credentials grant) ─────────────────
            Map<String, String> paymentSecrets = parseJsonSecret(
                data.get(paymentServiceAccount), "payment");
            secrets.put("action.oauth.payment.client-id",     
                getMandatorySecret(paymentSecrets, "client_id",     "payment"));
            secrets.put("action.oauth.payment.client-secret", 
                getMandatorySecret(paymentSecrets, "client_secret", "payment"));

            // ─── Notification OAuth (client_credentials grant) ────────────
            Map<String, String> notificationSecrets = parseJsonSecret(
                data.get(notificationServiceAccount), "notification");
            secrets.put("action.oauth.notification.client-id",     
                getMandatorySecret(notificationSecrets, "client_id",     "notification"));
            secrets.put("action.oauth.notification.client-secret", 
                getMandatorySecret(notificationSecrets, "client_secret", "notification"));

            log.info("Secrets mapped successfully for all services");
            return secrets;
        }

        log.error("Failed to fetch secrets. Status code: {}", response.getStatusCode());
        throw new IllegalStateException(
            String.format("Failed to fetch secrets. Status code: %s", response.getStatusCode()));
    }

    // ─── Helpers ──────────────────────────────────────────────────────────────

    /**
     * Parses a JSON secret string returned by the vault for a service.
     * Expected format: {"client_id":"x","client_secret":"y","username":"z","password":"w"}
     */
    private Map<String, String> parseJsonSecret(String rawSecret, String serviceName) {
        if (rawSecret == null || rawSecret.isBlank()) {
            throw new IllegalStateException(
                "Secret missing from vault response for service: " + serviceName);
        }
        try {
            ObjectMapper objectMapper = new ObjectMapper();
            return objectMapper.readValue(rawSecret, new TypeReference<Map<String, String>>() {});
        } catch (Exception e) {
            log.error("Failed to parse secret JSON for service: {}", serviceName);
            throw new IllegalStateException(
                "Failed to parse secret for service: " + serviceName, e);
        }
    }

    /**
     * Gets a mandatory key from parsed secret map, throws if missing.
     */
    private String getMandatorySecret(Map<String, String> secrets, String key, String serviceName) {
        return Optional.ofNullable(secrets.get(key))
            .filter(v -> !v.isBlank())
            .orElseThrow(() -> new IllegalStateException(
                "Missing '" + key + "' in vault secret for service: " + serviceName));
    }

    private RestTemplate buildRestTemplate() {
        HttpComponentsClientHttpRequestFactory factory =
            new HttpComponentsClientHttpRequestFactory();
        factory.setConnectTimeout(3000);
        factory.setReadTimeout(5000);
        return new RestTemplate(factory);
    }
}
