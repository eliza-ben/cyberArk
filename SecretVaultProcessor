
@Slf4j
public class SecretVaultProcessor implements EnvironmentPostProcessor {

  @Override
  public void postProcessEnvironment(
      ConfigurableEnvironment environment, SpringApplication application) {
    try {
      log.info("Inside code service's SecretVaultProcessor");
      String dbServiceAccount = environment.getProperty(DB_SERVICE_ACCOUNT.getName());
      String kafkaServiceAccount = environment.getProperty(KAFKA_SERVICE_ACCOUNT.getName());
      String secretServiceBaseUrl = environment.getProperty(SECRET_BASE_URL.getName());
      String secretApi = environment.getProperty(SECRET_API.getName());
      String secretApiUrl = secretServiceBaseUrl + secretApi;

      if (StringUtils.isEmpty(secretServiceBaseUrl)
          || StringUtils.isEmpty(dbServiceAccount)
          || StringUtils.isEmpty(kafkaServiceAccount)) {
        log.error(
            "Secret service URL and DB or Kafka service account must not be EMPTY or NULL. Secret URL: {} and DB Service account: {} and Kafka Service account: {}",
            secretServiceBaseUrl,
            dbServiceAccount,
            kafkaServiceAccount);
        throw new IllegalStateException(
            "Secret service URL or DB service account must not be EMPTY or NULL");
      }
      Map secrets = fetchSecrets(secretApiUrl, dbServiceAccount, kafkaServiceAccount);

      environment
          .getPropertySources()
          .addFirst(new MapPropertySource(GENESIS_SECRETS_MAPPING_SOURCE.getName(), secrets));
    } catch (Exception exception) {
      log.error("Failed to fetch secrets for Code Service application");
      throw new CodeServiceException(exception.getMessage());
    }
  }

  private Map<String, String> fetchSecrets(
      String secretServiceUrl, String dbServiceAccount, String kafkaServiceAccount) {
    RestTemplate restTemplate = buildRestTemplate();
    HttpHeaders headers = new HttpHeaders();
    headers.setContentType(MediaType.APPLICATION_JSON);
    headers.set(CORRELATION_ID_HEADER.getName(), UUID.randomUUID().toString());
    SecretsRequest secretsRequest =
        new SecretsRequest(List.of(dbServiceAccount, kafkaServiceAccount));
    HttpEntity<SecretsRequest> secretRequestEntity = new HttpEntity<>(secretsRequest, headers);
    ResponseEntity<Map<String, String>> response =
        restTemplate.exchange(
            secretServiceUrl,
            HttpMethod.POST,
            secretRequestEntity,
            new ParameterizedTypeReference<Map<String, String>>() {});

    if (response.getStatusCode().is2xxSuccessful()) {
      Map<String, String> data =
          Optional.ofNullable(response.getBody())
              .orElseThrow(() -> new IllegalStateException("Secret API returned empty body"));
      Map<String, String> secrets = new HashMap<>();
      secrets.put(DATABASE_PASSWORD.getName(), data.get(dbServiceAccount));
      secrets.put(KAFKA_PASSWORD.getName(), data.get(kafkaServiceAccount));
      return secrets;
    }
    log.error(
        "Failed to fetch secrets from secret API. Do further investigation for response code {}",
        response.getStatusCode());
    throw new IllegalStateException(
        String.format(
            "Failed to fetch secrets from secret API. Status code received: %s",
            response.getStatusCode()));
  }
