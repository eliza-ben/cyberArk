@Override
public void postProcessEnvironment(
        ConfigurableEnvironment environment, SpringApplication application) {
    try {
        log.info("Inside action service's SecretVaultProcessor");

        String secretServiceBaseUrl = environment.getProperty(SECRET_BASE_URL.getName());
        String secretApi            = environment.getProperty(SECRET_API.getName());
        String secretApiUrl         = secretServiceBaseUrl + secretApi;

        // ─── DB & Kafka ───────────────────────────────────────────────────
        String dbServiceAccount    = environment.getProperty(DB_SERVICE_ACCOUNT.getName());
        String kafkaServiceAccount = environment.getProperty(KAFKA_SERVICE_ACCOUNT.getName());

        // ─── Centrl — individual accounts per field ───────────────────────
        String centrlClientIdAccount     = environment.getProperty(CENTRL_CLIENT_ID_ACCOUNT.getName());
        String centrlClientSecretAccount = environment.getProperty(CENTRL_CLIENT_SECRET_ACCOUNT.getName());
        String centrlUsernameAccount     = environment.getProperty(CENTRL_USERNAME_ACCOUNT.getName());
        String centrlPasswordAccount     = environment.getProperty(CENTRL_PASSWORD_ACCOUNT.getName());

        // ─── Validate ─────────────────────────────────────────────────────
        if (StringUtils.isEmpty(secretServiceBaseUrl)
                || StringUtils.isEmpty(dbServiceAccount)
                || StringUtils.isEmpty(kafkaServiceAccount)
                || StringUtils.isEmpty(centrlClientIdAccount)
                || StringUtils.isEmpty(centrlClientSecretAccount)
                || StringUtils.isEmpty(centrlUsernameAccount)
                || StringUtils.isEmpty(centrlPasswordAccount)) {
            log.error(
                "One or more required service accounts are EMPTY or NULL. "
                + "Secret URL: {}, DB: {}, Kafka: {}, "
                + "Centrl clientId: {}, clientSecret: {}, username: {}, password: {}",
                secretServiceBaseUrl,
                dbServiceAccount,
                kafkaServiceAccount,
                centrlClientIdAccount,
                centrlClientSecretAccount,
                centrlUsernameAccount,
                centrlPasswordAccount);
            throw new IllegalStateException(
                "One or more required service accounts must not be EMPTY or NULL");
        }

        Map<String, String> secrets = fetchSecrets(
            secretApiUrl,
            dbServiceAccount,
            kafkaServiceAccount,
            centrlClientIdAccount,
            centrlClientSecretAccount,
            centrlUsernameAccount,
            centrlPasswordAccount
        );

        environment
            .getPropertySources()
            .addFirst(new MapPropertySource(GENESIS_SECRETS_MAPPING_SOURCE.getName(), secrets));

        log.info("Successfully loaded all secrets into Spring environment");

    } catch (Exception exception) {
        log.error("Failed to fetch secrets for Action Service application", exception);
        throw new ActionServiceException(exception.getMessage(), exception);
    }
}

// ─── Fetch Secrets ────────────────────────────────────────────────────────────

private Map<String, String> fetchSecrets(
        String secretServiceUrl,
        String dbServiceAccount,
        String kafkaServiceAccount,
        String centrlClientIdAccount,
        String centrlClientSecretAccount,
        String centrlUsernameAccount,
        String centrlPasswordAccount) {

    RestTemplate restTemplate = buildRestTemplate();

    HttpHeaders headers = new HttpHeaders();
    headers.setContentType(MediaType.APPLICATION_JSON);
    headers.set(CORRELATION_ID_HEADER.getName(), UUID.randomUUID().toString());

    SecretsRequest secretsRequest = new SecretsRequest(
        List.of(
            dbServiceAccount,
            kafkaServiceAccount,
            centrlClientIdAccount,       // each field is a separate vault key
            centrlClientSecretAccount,
            centrlUsernameAccount,
            centrlPasswordAccount
        )
    );

    HttpEntity<SecretsRequest> requestEntity = new HttpEntity<>(secretsRequest, headers);

    ResponseEntity<Map<String, String>> response =
        restTemplate.exchange(
            secretServiceUrl,
            HttpMethod.POST,
            requestEntity,
            new ParameterizedTypeReference<Map<String, String>>() {});

    if (response.getStatusCode().is2xxSuccessful()) {
        Map<String, String> data =
            Optional.ofNullable(response.getBody())
                .orElseThrow(() -> new IllegalStateException("Secret API returned empty body"));

        Map<String, String> secrets = new HashMap<>();

        // ─── DB & Kafka ───────────────────────────────────────────────────
        secrets.put(DATABASE_PASSWORD.getName(),
            Optional.ofNullable(data.get(dbServiceAccount))
                .orElseThrow(() -> new IllegalStateException("DB secret missing from response")));

        secrets.put(KAFKA_PASSWORD.getName(),
            Optional.ofNullable(data.get(kafkaServiceAccount))
                .orElseThrow(() -> new IllegalStateException("Kafka secret missing from response")));

        // ─── Centrl — map each field individually ─────────────────────────
        secrets.put("action.oauth.centrl.client-id",
            Optional.ofNullable(data.get(centrlClientIdAccount))
                .orElseThrow(() -> new IllegalStateException("Centrl client-id missing from response")));

        secrets.put("action.oauth.centrl.client-secret",
            Optional.ofNullable(data.get(centrlClientSecretAccount))
                .orElseThrow(() -> new IllegalStateException("Centrl client-secret missing from response")));

        secrets.put("action.oauth.centrl.username",
            Optional.ofNullable(data.get(centrlUsernameAccount))
                .orElseThrow(() -> new IllegalStateException("Centrl username missing from response")));

        secrets.put("action.oauth.centrl.password",
            Optional.ofNullable(data.get(centrlPasswordAccount))
                .orElseThrow(() -> new IllegalStateException("Centrl password missing from response")));

        log.info("Secrets mapped successfully for all services");
        return secrets;
    }

    log.error("Failed to fetch secrets. Status code: {}", response.getStatusCode());
    throw new IllegalStateException(
        String.format("Failed to fetch secrets. Status code: %s", response.getStatusCode()));
}
